064a\u0645 \u0648\u062a\u0631\u0643\u064a\u0628 \u063a\u0631\u0641 \u0632\u062c\u0627\u062c \u0644\u0644\u0645\u0638\u0644\u0627\u062a \u0648\u0627\u0644\u062c\u0644\u0633\u0627\u062a \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0628\u0623\u062d\u062f\u062b \u0627\u0644\u062a\u0635\u0627\u0645\u064a\u0645 \u0627\u0644\u0639\u0635\u0631\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u0636\u064a\u0641 \u0644\u0645\u0633\u0629 \u0645\u0646 \u0627\u0644\u0623\u0646\u0627\u0642\u0629 \u0648\u0627\u0644\u0641\u062e\u0627\u0645\u0629 \u0644\u0644\u0645\u0643\u0627\u0646. \u062a\u064f\u0639\u062f \u0627\u0644\u063a\u0631\u0641 \u0627\u0644\u0632\u062c\u0627\u062c\u064a\u0629 \u062e\u064a\u0627\u0631\u064b\u0627 \u0645\u062b\u0627\u0644\u064a\u064b\u0627 \u0644\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0645\u0646 \u0627\u0644\u0645\u0633\u0627\u062d\u0627\u062a \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0645\u0639 \u0627\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0627\u0644\u0625\u0637\u0644\u0627\u0644\u0629 \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629 \u0648\u0627\u0644\u0634\u0639\u0648\u0631 \u0628\u0627\u0644\u0631\u0627\u062d\u0629 \u0641\u064a \u0645\u062e\u062a\u0644\u0641 \u0627\u0644\u0623\u0648\u0642\u0627\u062a.<\/p><p>\u062a\u062a\u0645\u064a\u0632 \u0627\u0644\u063a\u0631\u0641 \u0627\u0644\u0632\u062c\u0627\u062c\u064a\u0629 \u0628\u0627\u0644\u0642\u0648\u0629 \u0648\u0627\u0644\u0645\u062a\u0627\u0646\u0629 \u0648\u0633\u0647\u0648\u0644\u0629 \u0627\u0644\u062a\u0646\u0638\u064a\u0641\u060c \u0643\u0645\u0627 \u062a\u0633\u0645\u062d \u0628\u062f\u062e\u0648\u0644 \u0627\u0644\u0636\u0648\u0621 \u0627\u0644\u0637\u0628\u064a\u0639\u064a \u0648\u062a\u0648\u0641\u0631 \u062d\u0645\u0627\u064a\u0629 \u0645\u0646 \u0627\u0644\u063a\u0628\u0627\u0631 \u0648\u0627\u0644\u0631\u064a\u0627\u062d \u0648\u0627\u0644\u0639\u0648\u0627\u0645\u0644 \u0627\u0644\u062c\u0648\u064a\u0629 \u0627\u0644\u0645\u062e\u062a\u0644\u0641\u0629. \u06